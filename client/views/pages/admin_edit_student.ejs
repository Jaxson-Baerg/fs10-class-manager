<!DOCTYPE html>
<html lang="en">
  	<head>
		<%- include('../partials/head'); %>
  	</head>
  	<body class="container">

	<header id="header" class="fixed-top">
	  	<%- include('../partials/header'); %>
	</header>

	<main>
		<div class="jumbotron">
		
			<a href="/admin"><button type="button" class="btn link-btn"><&nbsp;&nbsp;Back</button></a>

			<div class="section-title">
				<h1 class="text-center">Admin</h1>
				<h2 class="text-center">Edit Student</h2>
			</div>

      <% if (typeof message !== 'undefined' && message) { %>
      <div class="alert alert-success mt-3"><%= message %></div>
      <% } %>

			<div class="row justify-content-center">
			  	<div class="col-lg-10">
					<form id="edit-student" action="/admin/edit/student" method="POST" class="input-form flex-column">
						
						<input name="student_id" value="<%= student.student_id %>" hidden />

				  		<div class="form-group mt-2">
							<label for="first_name">First Name: </label>
							<input name="first_name" class="form-control" type="text" value="<%= student.first_name %>" required />
			  			</div>

						<div class="form-group mt-2">
							<label for="last_name">Last Name: </label>
							<input name="last_name" class="form-control" type="text" value="<%= student.last_name %>" required />
			  			</div>

						<div class="form-group mt-2">
							<label for="email">Email: </label>
							<input name="email" class="form-control" type="text" value="<%= student.email %>" required />
			  			</div>

						<div class="form-group mt-2">
							<label for="credits">Credits: </label>
							<input name="credits" class="form-control" type="number" value="<%= student.credits %>" required />
            </div>

            <div class="form-group mt-2">
              <label for="credit_audit_note">Credit Change Note: </label>
              <input name="credit_audit_note" class="form-control" type="text" placeholder="Reason for credit adjustment" />
            </div>

            <div class="row justify-content-center mt-4">
              <div class="col-lg-10">
                <div class="card p-3">
                  <h3>Credit Changes</h3>

                  <% if (!creditAudit || creditAudit.length === 0) { %>
                    <p>No credit change entries found.</p>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table">
                        <thead>
                          <tr>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Before</th>
                            <th>After</th>
                            <th>Description</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% creditAudit.forEach((entry, index) => { %>
                            <tr class="audit-row <%= index >= 2 ? 'audit-row-hidden' : '' %>">
                              <td><%= entry.changed_at %></td>
                              <td><%= entry.delta > 0 ? `+${entry.delta}` : entry.delta %></td>
                              <td><%= entry.credits_before %></td>
                              <td><%= entry.credits_after %></td>
                              <td><%= entry.description || '' %></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>

                    <% if (creditAudit.length > 2) { %>
                      <a href="#" id="show-more-audit">Show more</a>
                    <% } %>
                  <% } %>
                </div>
              </div>
            </div>

						<!-- TODO -->
						<!-- <div class="form-group mt-2">
							<label for="mailing_list">Mailing List: </label>
							<input id="mailing_list" name="mailing_list" class="form-control" type="checkbox" />
			  			</div> -->

						<div class="flex mt-2">
							<button type="submit">Submit</button>
						</div>
					</form>
		  		</div>
			</div>
	  	</div>
	</main>

	<footer>
	  	<%- include('../partials/footer'); %>
	</footer>

	<script>
	  	document.getElementById('edit-student').addEventListener('submit', e => {
			if (!confirm("Are you sure? This action cannot be undone.")) {
		  		e.preventDefault();
			}

			// if (document.getElementById('mailing_list').checked) {

			// }
	  	});

      const showMoreLink = document.getElementById('show-more-audit');
      if (showMoreLink) {
        showMoreLink.addEventListener('click', e => {
          e.preventDefault();

          document.querySelectorAll('.audit-row-hidden').forEach(row => {
            row.classList.remove('audit-row-hidden');
          });

          showMoreLink.style.display = 'none';
        });
      }
	</script>

  	</body>
</html>
